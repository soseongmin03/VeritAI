{
  "manifest_version": 3,
  "name": "Deepfake Detector",
  "version": "1.1",
  "description": "Detect deepfake images or video frames on web pages.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}